# ═══════════════════════════════════════════════════════════════════════════════
# ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE (Required)
# ═══════════════════════════════════════════════════════════════════════════════
# MySQL connection string
# Format: mysql://username:password@host:port/database
DATABASE_URL=mysql://root:password@localhost:3306/ssm_database

# ═══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION (Required for Admin Access)
# ═══════════════════════════════════════════════════════════════════════════════
# Generate a random secret key: openssl rand -base64 32
SESSION_SECRET=your-random-secret-key-here-change-this-in-production

# Admin user OpenID (for initial admin access)
OWNER_OPEN_ID=your-admin-openid-here

# ═══════════════════════════════════════════════════════════════════════════════
# AWS S3 STORAGE (Required for Image Uploads)
# ═══════════════════════════════════════════════════════════════════════════════
# Create AWS IAM user with S3 access
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# ═══════════════════════════════════════════════════════════════════════════════
# STRIPE PAYMENTS (Optional - for checkout)
# ═══════════════════════════════════════════════════════════════════════════════
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ═══════════════════════════════════════════════════════════════════════════════
# GOOGLE GEMINI AI (Optional - for AI product descriptions)
# ═══════════════════════════════════════════════════════════════════════════════
GEMINI_API_KEY=your-gemini-api-key

# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL / NOTIFICATIONS (Optional)
# ═══════════════════════════════════════════════════════════════════════════════
# For order notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ═══════════════════════════════════════════════════════════════════════════════
# HOSTING / DEPLOYMENT (Optional)
# ═══════════════════════════════════════════════════════════════════════════════
# Hostinger or your hosting provider settings
NODE_ENV=production
HOST=yourdomain.com

# ═══════════════════════════════════════════════════════════════════════════════
# DEVELOPMENT (Local development only)
# ═══════════════════════════════════════════════════════════════════════════════
# Set to "development" for local development
# NODE_ENV=development
